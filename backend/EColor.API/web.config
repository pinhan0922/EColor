<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <modules>
      <!-- 移除 WebDAV 模組，避免攔截 PUT/DELETE 和 OPTIONS 請求 -->
      <remove name="WebDAVModule" />
    </modules>
    <handlers>
      <!-- 移除 WebDAV 處理常式 -->
      <remove name="WebDAV" />
      <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
    </handlers>
    <aspNetCore processPath="dotnet" arguments=".\EColor.API.dll" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />
  </system.webServer>
</configuration>
